# Application
ENVIRONMENT=development
DEBUG=false

# Security - generate a strong secret key for production
SECRET_KEY=change-me-to-a-secure-random-string-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# SQLite example: sqlite:///./app.db
# PostgreSQL example: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://authservice:authservice_password@localhost:5432/auth_db

# CORS - comma separated origins, or * for all
CORS_ORIGINS=*
